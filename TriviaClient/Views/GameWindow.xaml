<Window x:Class="TriviaClient.Views.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="trivia game" Height="550" Width="800" WindowStartupLocation="CenterScreen" Background="#F4F4F9">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="questions left: " FontSize="18" Foreground="Gray"/>
                <TextBlock x:Name="TxtQuestionsRemaining" Text="5" FontSize="18" FontWeight="Bold" Foreground="Black" Margin="0,0,20,0"/>

                <TextBlock Text="correct answers: " FontSize="18" Foreground="Gray"/>
                <TextBlock x:Name="TxtCorrectAnswers" Text="0" FontSize="18" FontWeight="Bold" Foreground="Green"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="time left: " FontSize="18" Foreground="Gray"/>
                <TextBlock x:Name="TxtTimer" Text="10 seconds" FontSize="18" FontWeight="Bold" Foreground="#E53935"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,10" BorderBrush="#E0E0E0" BorderThickness="1">
            <TextBlock x:Name="TxtQuestion" Text="Here the question from the server will appear..." FontSize="24" FontWeight="Bold" 
                       TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" Foreground="#333333"/>
        </Border>

        <UniformGrid Grid.Row="2" Columns="2" Rows="2" Margin="0,10,0,0">
            <Button x:Name="BtnAnswer0" Content="Answer 1" FontSize="18" Background="#2196F3" Foreground="White" FontWeight="Bold" Margin="8" Click="AnswerButton_Click"/>
            <Button x:Name="BtnAnswer1" Content="Answer 2" FontSize="18" Background="#FF9800" Foreground="White" FontWeight="Bold" Margin="8" Click="AnswerButton_Click"/>
            <Button x:Name="BtnAnswer2" Content="Answer 3" FontSize="18" Background="#4CAF50" Foreground="White" FontWeight="Bold" Margin="8" Click="AnswerButton_Click"/>
            <Button x:Name="BtnAnswer3" Content="Answer 4" FontSize="18" Background="#9C27B0" Foreground="White" FontWeight="Bold" Margin="8" Click="AnswerButton_Click"/>
        </UniformGrid>
    </Grid>
</Window>