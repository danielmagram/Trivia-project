<Window x:Class="TriviaClient.Views.GameResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game Results" Height="500" Width="650" WindowStartupLocation="CenterScreen" Background="#F4F4F9">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFD700" CornerRadius="8" Padding="15" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Winner: " FontSize="22" FontWeight="Bold" Foreground="#333333"/>
                <TextBlock x:Name="TxtWinnerName" Text="Loading..." FontSize="22" FontWeight="Bold" Foreground="#111111"/>
            </StackPanel>
        </Border>

        <ListView x:Name="LvResults" Grid.Row="1" FontSize="16" BorderThickness="1" BorderBrush="#CCCCCC">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Player Name" DisplayMemberBinding="{Binding PlayerName}" Width="200"/>
                    <GridViewColumn Header="Correct Answers" DisplayMemberBinding="{Binding CorrectAnswers}" Width="150"/>
                    <GridViewColumn Header="Average Time (Sec)" DisplayMemberBinding="{Binding AverageTime}" Width="200"/>
                </GridView>
            </ListView.View>
        </ListView>

        <Button Grid.Row="2" Content="Return to Main Menu" Width="200" Height="40" 
                Background="#4CAF50" Foreground="White" FontSize="16" FontWeight="Bold" 
                Margin="0,20,0,0" HorizontalAlignment="Center" Click="BtnMainMenu_Click"/>
    </Grid>
</Window>