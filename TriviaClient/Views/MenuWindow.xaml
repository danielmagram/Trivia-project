<Window x:Class="TriviaClient.Views.MenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TriviaClient.Views"
        mc:Ignorable="d"
        Title="MenuWindow" Height="600" Width="800"
        Background="#F0F0F0">

    <Grid Margin = "20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" HorizontalAlignment="Left">
                <TextBlock Text="Hello:" FontSize="25" Foreground="ForestGreen"/>
                <TextBlock x:Name="UsernameText" Text="User" FontSize="30" FontWeight="Bold" Foreground="Black" Margin="50,0,0,0"/>
            </StackPanel>

            <TextBlock Grid.Column="1" Text="Trivia" FontSize="48" 
                       FontWeight="ExtraBold" HorizontalAlignment="Center" 
                       VerticalAlignment="Center" Foreground="ForestGreen"/>

            <Button Grid.Column="2" Content="Logout" Width="100" Height="40" 
                    HorizontalAlignment="Right" Background="Red" Foreground="White" BorderThickness="0" FontWeight="Bold" FontSize="15"
                    Click="Logout_Click"/>
        </Grid>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">

            <Button Content="Join Room" Margin="0,10" Padding="15" FontSize="20"
                    Background="White" BorderBrush="ForestGreen" BorderThickness="2" Click="JoinRoom_Click"/>

            <Button Content="Create Room" Margin="0,10" Padding="15" FontSize="20"
                    Background="White" BorderBrush="ForestGreen" BorderThickness="2" Click="CreateRoom_Click"/>

            <Button Content="My Stats" Margin="0,10" Padding="15" FontSize="20"
                    Background="White" BorderBrush="ForestGreen" BorderThickness="2" Click="MyStats_Click"/>

            <Button Content="Best Scores" Margin="0,10" Padding="15" FontSize="20"
                    Background="White" BorderBrush="ForestGreen" BorderThickness="2" Click="BestScores_Click"/>

            <Button Content="EXIT" Margin="0,30,0,10" Padding="10" FontSize="18" FontWeight="Bold" Width="100" Height="40"
                    Background="Red" Foreground="White" BorderThickness="0" Click="Quit_Click"/>

        </StackPanel>
    </Grid>
</Window>
