<Window x:Class="TriviaClient.Views.HighscoresWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="High Scores" Height="400" Width="300" WindowStartupLocation="CenterScreen">
    <Grid Margin="20" Background="Red">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
       
        <TextBlock Grid.Row="0" Text=" TOP SCORES " FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <ListBox x:Name="lstHighscores" Grid.Row="1" FontSize="16" Margin="0,0,0,15"
                 HorizontalContentAlignment="Center"/>

        <Button Grid.Row="2" Content="Back to Menu" Height="35" Click="btnBack_Click"/>
    </Grid>
</Window>