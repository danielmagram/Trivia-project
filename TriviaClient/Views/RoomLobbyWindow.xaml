<Window x:Class="TriviaClient.Views.RoomLobbyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TriviaClient.Views"
        mc:Ignorable="d"
        Title="RoomLobbyWindow" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" HorizontalAlignment="Left">
            <TextBlock Text="Hello:" FontSize="25" Foreground="ForestGreen"/>
            <TextBlock x:Name="UsernameText" Text="User" FontSize="30" FontWeight="Bold" Foreground="Black" Margin="50,0,0,0"/>
        </StackPanel>

        <TextBlock Text="Trivia" FontSize="34" FontWeight="Bold" Foreground="ForestGreen" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center"/>

        <Button Grid.Column="2" Content="LEAVE" Width="100" Height="40" 
        HorizontalAlignment="Right" Background="Red" Foreground="White" BorderThickness="0" FontWeight="Bold" FontSize="15"
        Click="LeaveButton_Click"/>

        <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Center">
            <TextBlock Text="players:" 
                       FontSize="18" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,200"/>

            <ListBox x:Name="ListPlayers" 
                     BorderThickness="0" 
                     Background="Transparent"
                     HorizontalContentAlignment="Center"
                     FontSize="16">
            </ListBox>
        </StackPanel>

        <Button Content="Update" 
                Click="UpdateButton_Click"
                
                Padding="15,5"
                Grid.Row="2" Grid.Column="2" 
                HorizontalAlignment="Right"
                Foreground ="white" Background="ForestGreen"/>
    </Grid>
</Window>
