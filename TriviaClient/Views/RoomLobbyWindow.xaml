<Window x:Class="TriviaClient.Views.RoomLobbyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TriviaClient.Views"
        mc:Ignorable="d"
        Title="RoomLobbyWindow" Height="550" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" HorizontalAlignment="Left">
            <TextBlock Text="Hello:" FontSize="25" Foreground="ForestGreen"/>
            <TextBlock x:Name="UsernameText" Text="User" FontSize="30" FontWeight="Bold" Foreground="Black" Margin="50,0,0,0"/>
        </StackPanel>

        <TextBlock Text="Trivia" FontSize="34" FontWeight="Bold" Foreground="ForestGreen" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center"/>


        <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,0,100">
            <TextBlock Text="players:" 
                       FontSize="18" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20"/>

            <ListBox x:Name="ListPlayers" 
                     BorderThickness="0" 
                     Background="Transparent"
                     HorizontalContentAlignment="Center"
                     FontSize="16">
            </ListBox>
        </StackPanel>
        <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,20">
            <Button x:Name="BtnStartGame" Content="START GAME" Width="130" Height="40" Background="#4CAF50" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,10,0" Visibility="Collapsed" Click="StartGameButton_Click"/>
            <Button x:Name="BtnCloseRoom" Content="CLOSE ROOM" Width="130" Height="40" Background="#F44336" Foreground="White" FontWeight="Bold" FontSize="14" Visibility="Collapsed" Click="CloseRoomButton_Click"/>

            <Button x:Name="BtnLeaveRoom" Content="LEAVE ROOM" Width="130" Height="40" Background="#FF9800" Foreground="White" FontWeight="Bold" FontSize="14" Visibility="Collapsed" Click="LeaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
