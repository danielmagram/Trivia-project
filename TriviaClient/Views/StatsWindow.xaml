<Window x:Class="TriviaClient.Views.StatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TriviaClient.Views"
        mc:Ignorable="d"
        Title="StatsWindow" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" HorizontalAlignment="Left">
                <TextBlock Text="Hello:" FontSize="25" Foreground="ForestGreen"/>
                <TextBlock x:Name="UsernameText" Text="User" FontSize="30" FontWeight="Bold" Foreground="Black" Margin="50,0,0,0"/>
            </StackPanel>

            <TextBlock Grid.Column="1" Text="TRIVIA" FontSize="28" FontWeight="Bold" 
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <Button Grid.Column="2" Content="BACK" Width="100" Height="40" 
        HorizontalAlignment="Right" Background="Red" Foreground="White" BorderThickness="0" FontWeight="Bold" FontSize="15"
        Click="BackButton_Click"/>
        </Grid>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="my stats" FontSize="22" FontWeight="SemiBold" 
                       HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <TextBlock x:Name="GamesCountText" Text="number of games: 0" FontSize="16" Margin="0,5"/>
            <TextBlock x:Name="TotalAnswersText" Text="number of answers: 0" FontSize="16" Margin="0,5"/>
            <TextBlock x:Name="RightAnswersText" Text="number of right answers: 0" FontSize="16" Margin="0,5"/>
            <TextBlock x:Name="ScoreText" Text="Score: 0" FontSize="16" Margin="0,5"/>
            <TextBlock x:Name="AvgTimeText" Text="average time for answer: 0s" FontSize="16" Margin="0,5"/>
            <Button Content="UPDATE" Width="90" Height="35" HorizontalAlignment="Center" Click="UpdateButton_Click" Margin="0,10"/>

        </StackPanel>
    </Grid>
</Window>
